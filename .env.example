# AI Idea Forge — Environment Variables
NODE_ENV=development
HOST=0.0.0.0
PORT=3210

# === Active provider selection ===
# Options: fake | omlx | freellmapi
DEFAULT_PROVIDER=freellmapi
DEFAULT_MODEL=

# === oMLX (Ollama-compatible local) ===
OMLX_BASE_URL=http://localhost:11434
OMLX_API_KEY=

# === FreeLLMApi (OpenAI-compatible remote) ===
FREELLMAPI_BASE_URL=https://api.freellmapi.com
FREELLMAPI_API_KEY=
FREELLMAPI_MODEL=auto

# === Run storage ===
RUN_STORAGE_DIR=./data/runs
MAX_AGENTS_PER_RUN=6
MAX_AGENT_OUTPUT_TOKENS=1200
TURN_TIMEOUT_MS=120000
RUN_TIMEOUT_MS=600000
PROVIDER_RETRY_ATTEMPTS=1

# === Misc ===
ENABLE_SSE=true
LOG_LEVEL=info
