{
  "name": "ai-idea-forge",
  "version": "0.1.0",
  "description": "Modularny workflow do generowania Decision Memo przez multi-agent AI pipeline",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "node backend/src/server.js",
    "start": "node backend/src/server.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --forceExit",
    "test:smoke": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/smoke/ --forceExit",
    "build": "cd frontend && npm install && npx vite build"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "vite": "^6.0.0"
  }
}
